sequenceDiagram
    autonumber
    participant BA as "Business Agent"
    participant P as "LLM Planner"
    participant LLM as "LLM Gateway"
    participant PV as "PlanValidator"
    participant E as "Graph Executor"
    participant CP as "Checkpoint Store"
    participant TR as "Tool Registry"
    participant TX as "Tool / Skill Executor"
    participant EXT as "External Systems"
    participant PR as "Policy Registry (Retry/Fallback)"
    participant OB as "Observability"

    BA->>P: Plan request (query + context)
    P->>LLM: Request structured plan (ExecutionPlan schema)
    LLM-->>P: Structured plan candidate
    P->>PV: Validate(plan + agent scope + limits)
    PV->>TR: Check tool existence + schema + auth scope
    TR-->>PV: Tool metadata
    alt Valid plan
        PV-->>P: Approved plan
        P-->>E: Dispatch validated plan + initial state
    else Invalid plan
        PV-->>P: Validation errors
        P->>LLM: Repair plan with validation feedback
        LLM-->>P: Repaired structured plan
        P->>PV: Re-validate plan
        alt Repaired plan valid
            PV-->>P: Approved repaired plan
            P-->>E: Dispatch validated plan + initial state
        else Still invalid
            PV-->>P: Fail closed / ask clarification
            P-->>BA: Return planning error or clarification request
        end
    end

    E->>CP: Load checkpoint(thread_id)
    alt Resume available
        CP-->>E: Restore state snapshot
    else New thread
        CP-->>E: Empty state
    end
    E->>OB: Start trace + execution metadata

    loop For each task
        E->>TR: Resolve tool binding
        TR-->>E: Tool impl + schema

        TX->>OB: Start tool span
        E->>TX: Execute(tool, params, timeout)
        TX->>EXT: Perform call

        alt Success
            EXT-->>TX: Result
            TX-->>E: Normalized output
        else Tool error / timeout
            EXT-->>TX: Error
            TX->>PR: Retry + fallback decision
            alt Retry allowed
                PR-->>TX: Retry budget + backoff
                TX->>EXT: Retry call
                EXT-->>TX: Result / error
                TX-->>E: Output / final error
            else Need re-plan
                PR-->>E: Replan required
                E->>P: Ask for revised plan (include failure)
                P->>LLM: Request revised structured plan
                LLM-->>P: Revised plan candidate
                P->>PV: Validate revised plan
                PV->>TR: Re-check tool binding + deps
                TR-->>PV: Tool metadata
                PV-->>P: Approved revised plan
                P-->>E: Revised validated plan
            end
        end

        E->>CP: Save checkpoint(state + tool trace)
        CP-->>E: Ack
        TX-->>OB: End tool span (status + cost + latency)
    end

    E-->>BA: Final state + answer payload
    BA-->>OB: Emit summary metrics (success/fallback rate)
